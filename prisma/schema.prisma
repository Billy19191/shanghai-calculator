// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  // Expenses this user paid for
  paidExpenses  Expense[]      @relation("PaidExpenses")
  // Portions of expenses this user owes to the payer
  expenseShares ExpenseShare[]
}

model Expense {
  id     Int      @id @default(autoincrement())
  name   String // e.g. "Dinner", "Taxi"
  amount Float // Total cost
  date   DateTime @default(now())

  payerId Int
  payer   User @relation("PaidExpenses", fields: [payerId], references: [id])

  shares ExpenseShare[]
}

model ExpenseShare {
  id Int @id @default(autoincrement())

  expenseId Int
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  userId Int // The user who participated in this expense
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  amountOwed Float // The amount this user needs to pay back
  isPaid     Boolean @default(false)

  @@unique([expenseId, userId])
}
